{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "C++ UI Runtime",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "C:\\Windows\\System32\\cmd.exe",
      "args": [
        "/c",
        "${workspaceFolder}\\app\\cpp\\ui_runtime\\run_windows.bat"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "stopAtEntry": false
    }
  ]
}
